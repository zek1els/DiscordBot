# Get your bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Optional: your server (guild) ID for instant slash command updates during development
# GUILD_ID=your_guild_id_here

# Web app: login with Discord (required for the panel). Same Discord app as the bot.
# In Developer Portal → OAuth2 → Redirects, add: https://YOUR_PUBLIC_URL/api/auth/discord/callback
# DISCORD_CLIENT_ID=your_application_id   (Developer Portal → your app → Application ID)
# DISCORD_CLIENT_SECRET=your_client_secret (Developer Portal → OAuth2 → Client Secret, click Reset to reveal)
# PUBLIC_URL=https://your-app.up.railway.app

# Comma-separated Discord user IDs that are admins. Admins see ALL scheduled messages; others see only their own.
# If empty, no one is admin (everyone sees only their own).
# ADMIN_DISCORD_IDS=123456789012345678,987654321098765432

# Optional: API key for script/programmatic access (full admin). No user context.
# API_KEY=your_secret_key

# Optional: port for the web app (default 3000)
# PORT=3000

# Optional: persistent data directory. On Railway, set to /data and add a Volume.
# DATA_DIR=/data

# Optional: SMTP for email verification on registration.
# If not set, registration works without email verification.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM=you@gmail.com
