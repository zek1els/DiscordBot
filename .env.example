# Get your bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Optional: your server (guild) ID for instant slash command updates during development
# GUILD_ID=your_guild_id_here

# Admin login for the web app (recommended on Railway). Users must enter this password to see the scheduler.
# ADMIN_PASSWORD=your_admin_password

# Optional: API key for script/programmatic access. If set, requests with X-API-Key can also access the API.
# API_KEY=your_secret_key

# Optional: port for the web app (default 3000)
# PORT=3000

# Optional: persistent data directory. On Railway, set to /data and add a Volume mounted at /data so schedules and saved messages survive deploys.
# DATA_DIR=/data
